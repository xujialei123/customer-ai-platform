{
  "_fileDescription": "Chrome MV3 扩展权限、匹配域名和脚本声明。",
  "_fileModule": "RPA 与 Chrome 插件",
  "_relatedModules": "版本号与 host_permissions。",
  "manifest_version": 3,
  "name": "客服中台 RPA 助手",
  "version": "0.3.30",
  "description": "在 Chrome 登录会话中同时桥接美团经营宝与抖音来客消息到本地客服中台。",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webNavigation",
    "alarms",
    "dom"
  ],
  "host_permissions": [
    "http://127.0.0.1:3001/*",
    "http://127.0.0.1:3100/*",
    "http://localhost:3100/*",
    "https://g.dianping.com/*",
    "https://ecom.meituan.com/*",
    "https://life.douyin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:3100/*",
        "http://localhost:3100/*",
        "https://g.dianping.com/*",
        "https://ecom.meituan.com/*",
        "https://life.douyin.com/*"
      ],
      "js": [
        "platform-profiles.js",
        "content.js"
      ],
      "all_frames": true,
      "match_origin_as_fallback": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "客服中台 RPA 助手",
    "default_popup": "popup.html"
  }
}
