# @file .env.example
# @module 根目录与配置
# @description 环境变量示例模板，复制为 .env 后填写。
# @see 联动关注：env.ts 与各 Service 读取项。
# 服务配置
NODE_ENV=development
API_PORT=3001
RAG_SERVICE_PORT=8787
RAG_API_KEY=local-dev-key

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/customer_ai
REDIS_URL=redis://127.0.0.1:6379

# 向量库配置
VECTOR_STORE=pgvector
VECTOR_DIM=1536

# Embedding 配置（也可在 http://127.0.0.1:3001/guide 配置页热更新）
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your_embedding_key
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1536

# LLM 配置：优先用 /guide 配置页（Agnes 或自定义 OpenAI 兼容）
# agnes | openai-compatible | openclaw
LLM_PROVIDER=agnes
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=agnes-2.0-flash

# Agnes 直连（LLM_PROVIDER=agnes）
AGNES_API_URL=https://apihub.agnes-ai.com/v1/chat/completions
AGNES_API_KEY=your_agnes_key
AGNES_MODEL=agnes-2.0-flash
# 兼容旧拼写
AGENES_API_URL=
AGENES_API_KEY=

# OpenClaw 本地网关（仅 LLM_PROVIDER=openclaw 时需要）
# 便携包交付后无需填写 OPENCLAW_PORTABLE_ROOT / OPENCLAW_TOKEN_FILE。
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_PORTABLE_ROOT=
OPENCLAW_TOKEN_FILE=
OPENCLAW_AUTO_START=false
OPENCLAW_MODEL=openclaw/default
OPENCLAW_AGENT_ID=main
OPENCLAW_CHAT_ENDPOINT=/v1/chat/completions
OPENCLAW_TIMEOUT_MS=30000

# 企业微信客服配置，占位
WECOM_CORP_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=
WECOM_AGENT_ID=0

# 公司订单系统 Adapter。真实接口路径和鉴权方式必须按公司接口文档填写。
ORDER_ADAPTER_MODE=mock
ORDER_API_QUERY_URL_TEMPLATE=
ORDER_API_AUTH_HEADER=
ORDER_API_AUTH_VALUE=
ORDER_API_TIMEOUT_MS=8000

# 已跑通旧网关的公司订单后台配置；真实值只放 .env，禁止提交。
ADMIN_BASE_URL=
ADMIN_LOGIN_PATH=/api/auth/b/doLogin
ADMIN_ORDER_LIST_PATH=/api/biz/cxorderlaundry/page
ADMIN_TOKEN=
ADMIN_TENCODE=
ADMIN_ACCOUNT=
ADMIN_PASSWORD=
ADMIN_ORDER_SEARCH_KEY_FIELD=searchKey
ADMIN_ORDER_PAGE_CURRENT_FIELD=current
ADMIN_ORDER_PAGE_SIZE_FIELD=size
ADMIN_ORDER_PAGE_CURRENT=1
ADMIN_ORDER_PAGE_SIZE=10

# RAG 参数
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.72
RAG_HARD_FLOOR=0.35
RAG_MAX_CONTEXT_CHARS=6000
RAG_HISTORY_TURNS=6
RAG_USE_RERANK=false

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
SUPPORTED_FILE_TYPES=txt,md,pdf,docx,csv,xlsx

# RPA 配置
RAG_SERVICE_URL=http://127.0.0.1:8787
# 默认使用 Chrome 扩展处理 Mock；仅排查旧实现时才改为 playwright。
RPA_MOCK_MODE=extension
RPA_EXTENSION_BROWSER_AUTO_OPEN=true
# 系统未安装在默认目录时填写 chrome.exe 的绝对路径。
CHROME_PATH=
RPA_AUTO_REPLY=false
RPA_DRY_RUN=true
RPA_REPLY_DELAY_MS=800
RPA_DEDUPE_TTL_SECONDS=120
RPA_MAX_REPLY_CHARS=500
AUTO_REPLY_ENABLED=false
RPA_AUTO_SEND_ENABLED=false
MEITUAN_RPA_ENABLED=false
MEITUAN_RPA_MODE=extension
# 真实美团经营宝灰度时只处理这些测试 customerId/conversationId；留空=全部客户可回复。也可在 /guide 配置页编辑。
MEITUAN_RPA_ALLOWED_CUSTOMERS=
# 抖音来客白名单；留空=全部客户可回复。也可在 /guide 配置页编辑。
DOUYIN_RPA_ALLOWED_CUSTOMERS=
MEITUAN_RPA_URL="https://g.dianping.com/dzim-main-pc/index.html#/"
MEITUAN_RPA_USER_DATA_DIR=.sessions/meituan-production
MEITUAN_RPA_REPLY_INPUT_SELECTOR=.dzim-chat-input-container[contenteditable="plaintext-only"]
# 经营宝发送按钮；若页面改版导致点不到，用插件「自动配置」或 DOM 快照重新确认。
MEITUAN_RPA_SEND_BUTTON_SELECTOR=.dzim-chat-input-send > button.dzim-button-primary
