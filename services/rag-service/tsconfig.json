{
  "_fileDescription": "RAG 服务 TypeScript 严格编译配置。",
  "_fileModule": "RAG Service 兼容层",
  "_relatedModules": "所有新增 src 源码。",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}
