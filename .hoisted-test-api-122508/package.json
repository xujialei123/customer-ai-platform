{
  "name": "@customer-ai/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:all": "tsx src/dev/run-all.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "rpa:mock-site": "tsx src/rpa/mock-chat-server.ts",
    "rpa:mock-watch": "tsx src/rpa/mock-site.watcher.ts",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@customer-ai/rpa-sdk": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/formbody": "^8.0.2",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.34.2",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^5.9.0",
    "fastify": "^5.1.0",
    "ioredis": "5.10.1",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "playwright": "^1.49.0",
    "sm-crypto": "^0.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
